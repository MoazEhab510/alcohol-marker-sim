{
  "title": "Alcohol Marker Production Line",
  "uid": "alcohol-marker-001",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Machine State",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "IDLE": {
                  "text": "IDLE",
                  "color": "gray"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "RUNNING": {
                  "text": "RUNNING",
                  "color": "green"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "FAULTED": {
                  "text": "FAULTED",
                  "color": "red"
                }
              }
            }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"markers\")\n  |> range(start: -1m)\n  |> filter(fn: (r) => r._measurement == \"production\" and r._field == \"fsm_state\")\n  |> last()",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      }
    },
    {
      "id": 2,
      "title": "Parts Produced",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"markers\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"production\" and r._field == \"parts_produced\")\n  |> last()",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      }
    },
    {
      "id": 3,
      "title": "Ethanol Concentration (%)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 70
              },
              {
                "color": "red",
                "value": 91
              }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"markers\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"production\" and r._field == \"ethanol_pct\")\n  |> filter(fn: (r) => r._value > 0)",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      }
    },
    {
      "id": 4,
      "title": "Temperature (\u00b0C)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"markers\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"production\" and r._field == \"temperature_c\")",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      }
    },
    {
      "id": 5,
      "title": "Parts Defective",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "unit": "short"
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"markers\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"production\" and r._field == \"parts_defective\")\n  |> last()",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      }
    },
    {
      "id": 6,
      "title": "Cycle Time (s)",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 8,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "influxdb"
          },
          "query": "from(bucket: \"markers\")\n  |> range(start: -15m)\n  |> filter(fn: (r) => r._measurement == \"production\" and r._field == \"cycle_time_s\")\n  |> filter(fn: (r) => r._value > 0)\n  |> last()",
          "refId": "A"
        }
      ],
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb"
      }
    }
  ]
}